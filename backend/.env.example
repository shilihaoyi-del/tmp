# Environment overrides (copy to .env on server if needed)
APP_HOST=0.0.0.0
APP_PORT=8000
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_CLIENT_ID=arm-backend
HEARTBEAT_TIMEOUT_SEC=3.0
COMMAND_TTL_MS=500

# Hardware-less demo (set false when real SC171V2 is online)
ENABLE_SIMULATOR=true
SIM_SOURCE_LABEL=SIM
MODULE_ID=SC171V2
MODULE_NAME=Fibocom SC171V2
DEFAULT_CARRIER=5G/Wi-Fi
